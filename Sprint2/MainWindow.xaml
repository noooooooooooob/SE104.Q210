<Window x:Class="Sprint2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lập Phiếu Nhập Game"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- THÔNG TIN NHẬP GAME -->
        <GroupBox Header="Thông Tin Game"
                  FontSize="14"
                  Padding="10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Ngày nhập:"/>

                <DatePicker x:Name="dpNgayNhap"
                            Grid.Row="0"
                            Grid.Column="1"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Tên Game:"/>

                <TextBox x:Name="txtTenGame"
                         Grid.Row="1"
                         Grid.Column="1"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Loại Game:"/>

                <ComboBox x:Name="cbLoaiGame"
                          Grid.Row="2"
                          Grid.Column="1"/>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Nhà phát hành:"/>

                <TextBox x:Name="txtNhaPhatHanh"
                         Grid.Row="3"
                         Grid.Column="1"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Năm phát hành:"/>

                <TextBox x:Name="txtNamPhatHanh"
                         Grid.Row="4"
                         Grid.Column="1"/>

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Trị giá:"/>

                <TextBox x:Name="txtTriGia"
                         Grid.Row="5"
                         Grid.Column="1"/>

                <Button x:Name="btnThemGame"
                        Grid.Row="6"
                        Grid.Column="1"
                        Width="150"
                        Height="35"
                        HorizontalAlignment="Left"
                        Content="Thêm Game"
                        Click="BtnThemGame_Click"/>

            </Grid>

        </GroupBox>

        <!-- DANH SÁCH GAME -->
        <DataGrid x:Name="dgGames"
                  Grid.Row="1"
                  Margin="0,15,0,15"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Tên Game"
                                    Binding="{Binding TenGame}"
                                    Width="*"/>

                <DataGridTextColumn Header="Loại Game"
                                    Binding="{Binding LoaiGame}"
                                    Width="120"/>

                <DataGridTextColumn Header="Nhà Phát Hành"
                                    Binding="{Binding NhaPhatHanh}"
                                    Width="180"/>

                <DataGridTextColumn Header="Năm Phát Hành"
                                    Binding="{Binding NamPhatHanh}"
                                    Width="120"/>

                <DataGridTextColumn Header="Trị Giá"
                                    Binding="{Binding TriGia}"
                                    Width="120"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- PHẦN CUỐI -->
        <StackPanel Grid.Row="2">

            <TextBlock x:Name="txtTongGiaTri"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       Text="Tổng giá trị: 0"/>

            <Button x:Name="btnLapPhieu"
                    Width="200"
                    Height="40"
                    Content="Lập Phiếu Nhập"
                    Click="BtnLapPhieu_Click"/>

        </StackPanel>

    </Grid>

</Window>