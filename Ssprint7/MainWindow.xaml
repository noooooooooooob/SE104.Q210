<Window x:Class="Sprint7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lập phiếu ghi nhận mất Game"
        Height="520" Width="780"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Border BorderBrush="Black" BorderThickness="1" CornerRadius="8" Margin="10" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="65"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <TextBlock Grid.Row="0" Text="Lập phiếu ghi nhận mất Game"
                       FontSize="22" FontWeight="Bold" Margin="20,12,0,12"/>

            <Border Grid.Row="1" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nội dung -->
            <Border Grid.Row="2" Margin="12,12,12,12" Padding="14"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="5" Background="#EEF1F5">
                <StackPanel>

                    <!-- HÀNG 1: Mã phiếu mất | Họ tên KH | Ngày ghi nhận | Tổng tiền phạt -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mã phiếu mất -->
                        <StackPanel Grid.Column="0">
                            <Label Content="Mã phiếu mất" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbMaPhieuMat"
                                           Text="&lt;Giá trị phát sinh&gt;"
                                           FontSize="13" Foreground="#888"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <!-- Họ tên khách hàng -->
                        <StackPanel Grid.Column="2">
                            <Label Content="Họ tên khách hàng" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="White">
                                <ComboBox x:Name="cboKhachHang" Height="32" FontSize="13"
                                          BorderThickness="0" VerticalContentAlignment="Center"
                                          SelectionChanged="CboKhachHang_SelectionChanged"/>
                            </Border>
                        </StackPanel>

                        <!-- Ngày ghi nhận -->
                        <StackPanel Grid.Column="4">
                            <Label Content="Ngày ghi nhận" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="White">
                                <DatePicker x:Name="dtpNgayGhiNhan" Height="32" FontSize="13"
                                            BorderThickness="0" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Tổng tiền phạt -->
                        <StackPanel Grid.Column="6">
                            <Label Content="Tổng tiền phạt" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbTongTienPhat" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- BẢNG GAME MẤT -->
                    <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Grid Grid.Row="0" Background="#D0D0D0" Height="32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="STT" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="TÊN GAME" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="NGÀY MƯỢN" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="TIỀN PHẠT" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Các dòng game -->
                            <StackPanel Grid.Row="1" x:Name="pnlDongGame"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <Border Grid.Row="3" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nút bấm -->
            <Grid Grid.Row="4" Margin="12,12,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Lập phiếu ghi nhận mất Game"
                        Height="42" Width="260" FontSize="16"
                        Background="#00BCD4" Foreground="White" BorderThickness="1"
                        Click="BtnLapPhieu_Click"/>

                <Button Grid.Column="2" Content="Tìm khách hàng"
                        Height="42" Width="160" FontSize="16"
                        Background="#00BCD4" Foreground="White" BorderThickness="1"
                        Click="BtnTimKhachHang_Click"/>

                <Button Grid.Column="4" Content="Thoát"
                        Height="42" Width="100" FontSize="16"
                        Background="#00BCD4" Foreground="White" BorderThickness="1"
                        Click="BtnThoat_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>