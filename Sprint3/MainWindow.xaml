<Window x:Class="Sprint3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sprint3"
        mc:Ignorable="d"
        Title="Tra cứu Game" Height="650" Width="1600">
    <Border BorderBrush="Black" BorderThickness="1" Margin="10" CornerRadius="8" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="75"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <TextBlock Grid.Row="0"
                       Text="Tra cứu Game"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="20,10,0,10"/>

            <!-- Đường kẻ ngang -->
            <Border Grid.Row="1" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>


            <!-- Box bao quanh -->
            <Border Grid.Row="2" 
                    BorderBrush="#CCCCCC" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Background="#FFDDE3E7" 
                    Margin="10,15,10,10" 
                    Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>






                    <Grid Grid.Row="0" Margin="12,-12,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Mã CT phiếu nhập" FontSize="24"/>

                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>
                        </StackPanel>



                        <StackPanel Grid.Column="2">
                            <Label Content="Ngày nhập" FontSize="24"/>

                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40" Background="White">
                                <DatePicker Height="40" FontSize="24" BorderThickness="0" Language="vi-VN" Background="White" VerticalContentAlignment="Center">
                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="IsReadOnly" Value="True"/>
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                            </Border>
                        </StackPanel>



                        <StackPanel Grid.Column="4">
                            <Label Content="Tên Game" FontSize="24"/>

                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>
                        </StackPanel>



                        <StackPanel Grid.Column="6">
                            <Label Content="Tên loại Game" FontSize="24"/>

                            <ComboBox Height="40" FontSize="24" VerticalContentAlignment="Center"/>
                        </StackPanel>



                        <StackPanel Grid.Column="8">
                            <Label Content="Nhà phát hành" FontSize="24"/>

                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>
                        </StackPanel>





                    </Grid>



                    <Grid Grid.Row="1" Margin="12,12,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Năm phát hành " FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Text="từ" Foreground="#E26B67" FontSize="24" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>

                            <TextBlock Grid.Column="2" Text="đến" Foreground="#E26B67" FontSize="24" VerticalAlignment="Center" Margin="15,0"/>

                            <Border Grid.Column="3" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Trị giá " FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Text="từ" Foreground="#E26B67" FontSize="24" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>

                            <TextBlock Grid.Column="2" Text="đến" Foreground="#E26B67" FontSize="24" VerticalAlignment="Center" Margin="15,0"/>

                            <Border Grid.Column="3" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>
                        </Grid>
                    </Grid>







                    <Grid Grid.Row="2" Margin="12,12,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Tổng trị giá phiếu nhập " FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Text="từ" Foreground="#E26B67" FontSize="24" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>

                            <TextBlock Grid.Column="2" Text="đến" Foreground="#E26B67" FontSize="24" VerticalAlignment="Center" Margin="15,0"/>

                            <Border Grid.Column="3" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                <TextBox Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center" Margin="1,0,1,0"/>
                            </Border>
                        </Grid>

                    </Grid>










                    <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="2" CornerRadius="5" Background="White" Margin="12,12,12,12" Padding="10">

                        <DataGrid AutoGenerateColumns="False" 
                            CanUserAddRows="False"
                            HeadersVisibility="Column" 
                            GridLinesVisibility="All" 
                            HorizontalGridLinesBrush="#CCCCCC" 
                            VerticalGridLinesBrush="#CCCCCC" 
                            Background="White" 
                            BorderThickness="0"
                            FontSize="20"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto"
                            VirtualizingPanel.ScrollUnit="Pixel">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Height" Value="40"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="#F9FBFD"/>
                                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="45"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="NGÀY NHẬP" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="12" Margin="5,3" Background="#808080" Height="30"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="TÊN GAME" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="12" Margin="5,3" Background="#808080" Height="30"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="TÊN LOẠI GAME" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="12" Margin="5,3" Background="#808080" Height="30"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="NHÀ PHÁT HÀNH" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="12" Margin="5,3" Background="#808080" Height="30"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="NĂM PHÁT HÀNH" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="12" Margin="5,3" Background="#808080" Height="30"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="TRỊ GIÁ" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="12" Margin="5,3" Background="#808080" Height="30"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="TÌNH TRẠNG" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="12" Margin="5,3" Background="#808080" Height="30"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>


                </Grid>
            </Border>


            <!-- Đường kẻ ngang -->
            <Border Grid.Row="3" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>


            
            <!-- Nút bấm -->
            <Grid Grid.Row="4" Margin="12,10,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Tra cứu Game"
                        Height="45" Width="250"
                        HorizontalAlignment="Left"
                        FontSize="20"
                        Background="#00BCD4"
                        Foreground="White"
                        BorderThickness="1"/>

                <Button Grid.Column="1" Content="Thoát"
                        Height="45" Width="120"
                        FontSize="20"
                        Background="#00BCD4"
                        Foreground="White"
                        BorderThickness="1"
                        Click="BtnThoat_Click"/>
            </Grid>


        </Grid>
    </Border>
</Window>
