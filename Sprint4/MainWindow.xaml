<Window x:Class="Sprint4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lập phiếu cho mượn Game"
        Height="610"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Border BorderBrush="Black"
            BorderThickness="1"
            CornerRadius="8"
            Margin="10">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="435"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Grid Grid.Row="0">
                <TextBlock Text="Lập phiếu cho mượn Game"
                           FontSize="26"
                           Margin="20,15"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </Grid>

            <Border Grid.Row="1"
                    BorderBrush="#AAAAAA"
                    BorderThickness="0,1,0,0"/>

            <!-- Nội dung -->
            <Border Grid.Row="2"
                    Margin="15"
                    Padding="20"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="#EEF1F5">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ROW 1 -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Họ tên khách hàng" FontSize="18"/>
                            <ComboBox Height="40" FontSize="24" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Ngày hết hạn" FontSize="18"/>
                            <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                                <TextBlock FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <Label Content="Ngày mượn" FontSize="18"/>
                            <Border BorderBrush="#AAAAAA"
                    BorderThickness="1"
                    CornerRadius="5"
                    Height="40"
                    Background="White">

                                <DatePicker Height="40"
                            FontSize="24"
                            BorderThickness="0"
                            Language="vi-VN"
                            Background="White">

                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="IsReadOnly" Value="True"/>
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DatePicker.Resources>

                                </DatePicker>
                            </Border>
                        </StackPanel>

                    </Grid>

                    <!-- ROW 2 -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Tên game" FontSize="18"/>
                            <ComboBox Height="40" FontSize="24" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Tên loại game" FontSize="18"/>
                            <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                                <TextBlock FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                    </Grid>

                    <!-- ROW 3 -->
                    <Grid Grid.Row="2" Margin="0,0,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Nhà phát hành" FontSize="18"/>
                            <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                                <TextBlock FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Tình trạng" FontSize="18"/>
                            <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                                <TextBlock FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                    </Grid>

                    <!-- ROW 4 -->
                    <Grid Grid.Row="3">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Quy định số game cho mượn" FontSize="18"/>
                            <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                                <TextBlock FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Quy định số ngày mượn" FontSize="18"/>
                            <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                                <TextBlock FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                    </Grid>

                </Grid>

            </Border>

            <Border Grid.Row="3"
                    BorderBrush="#AAAAAA"
                    BorderThickness="0,1,0,0"/>
            
            

        </Grid>

    </Border>

</Window>