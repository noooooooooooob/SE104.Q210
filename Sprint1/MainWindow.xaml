<Window x:Class="Sprint1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo thẻ khách hàng"
        Width="1080" Height="720"
        WindowStartupLocation="CenterScreen">
    <Border BorderBrush="Black" BorderThickness="1" Margin="10" CornerRadius="8" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <TextBlock Grid.Row="0"
                       Text="Thẻ khách hàng"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="20,10,0,10"/>

            <!-- Đường kẻ ngang -->
            <Border Grid.Row="1" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Họ và tên + Mã khách hàng -->
            <Grid Grid.Row="2" Margin="12,12,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="115"/>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="265"/>
                    <ColumnDefinition Width="210"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Họ và tên" VerticalAlignment="Center" FontSize="24"/>
                <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Margin="8,0,8,0">
                    <TextBox x:Name="txtHoTen" Height="35" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center"/>
                </Border>
                <Label Grid.Column="2" Content="Mã khách hàng" VerticalAlignment="Center" FontSize="24" Margin="70,0,0,0"/>
                <Border Grid.Column="3" Background="#E0E0E0" Height="40" CornerRadius="5">
                    <TextBlock x:Name="txtMaKH" Text="&lt;Giá trị phát sinh&gt;" Foreground="Gray"
                               FontStyle="Italic" FontSize="24"
                               VerticalAlignment="Center" Margin="4,0"/>
                </Border>
            </Grid>

            <!-- Ngày sinh + Tuổi khách hàng -->
            <Grid Grid.Row="3" Margin="12,6,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="115"/>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="265"/>
                    <ColumnDefinition Width="210"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Ngày sinh" VerticalAlignment="Center" FontSize="24"/>
                <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Margin="8,0,8,0">
                    <DatePicker x:Name="dpNgaySinh" Height="40" FontSize="24" BorderThickness="0" Language="vi-VN"
                                SelectedDateChanged="dpNgaySinh_SelectedDateChanged">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="IsReadOnly" Value="True"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                </Border>
                <Label Grid.Column="2" Content="Tuổi khách hàng" VerticalAlignment="Center" FontSize="24" Margin="70,0,0,0"/>
                <Border Grid.Column="3" Background="#E0E0E0" Height="40" CornerRadius="5">
                    <TextBlock x:Name="txtTuoi" Text="&lt;Giá trị xử lý&gt;" Foreground="Gray"
                               FontStyle="Italic" FontSize="24"
                               VerticalAlignment="Center" Margin="4,0"/>
                </Border>
            </Grid>

            <!-- Quy định độ tuổi -->
            <Grid Grid.Row="5" Margin="12,6,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Quy định độ tuổi tối thiểu" FontSize="24" Margin="0,0,0,4"/>
                    <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                        <TextBlock x:Name="txtTuoiToiThieu" FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Quy định độ tuổi tối đa" FontSize="24" Margin="0,0,0,4"/>
                    <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                        <TextBlock x:Name="txtTuoiToiDa" FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- CCCD, SĐT, Email, Địa chỉ -->
            <Grid Grid.Row="6" Margin="12,6,12,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CCCD -->
                <Label Grid.Row="0" Grid.Column="0" Content="CCCD" VerticalAlignment="Center" FontSize="24"/>
                <Border Grid.Row="0" Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="3" CornerRadius="5" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtCCCD" Grid.Column="0" Height="40" BorderThickness="0" FontSize="24"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="NumberOnly_PreviewTextInput"/>
                        <TextBlock Grid.Column="1" Text="Nhập từ 0 - 9"
                                   Foreground="Gray" FontStyle="Italic" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- SĐT -->
                <Label Grid.Row="1" Grid.Column="0" Content="SĐT" VerticalAlignment="Center" FontSize="24"/>
                <Border Grid.Row="1" Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="3" CornerRadius="5" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtSDT" Grid.Column="0" Height="40" BorderThickness="0" FontSize="24"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="NumberOnly_PreviewTextInput"/>
                        <TextBlock Grid.Column="1" Text="Nhập từ 0 - 9"
                                   Foreground="Gray" FontStyle="Italic" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- Email -->
                <Label Grid.Row="2" Grid.Column="0" Content="Email" VerticalAlignment="Center" FontSize="24"/>
                <Border Grid.Row="2" Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="3" CornerRadius="5" Margin="0,0,0,10">
                    <TextBox x:Name="txtEmail" Height="40" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center"/>
                </Border>

                <!-- Địa chỉ -->
                <Label Grid.Row="3" Grid.Column="0" Content="Địa chỉ" VerticalAlignment="Center" FontSize="24"/>
                <Border Grid.Row="3" Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="3" CornerRadius="5">
                    <TextBox x:Name="txtDiaChi" Height="40" BorderThickness="0" FontSize="24" VerticalContentAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Tên loại KH + Ngày lập thẻ + Ngày hết hạn -->
            <Grid Grid.Row="7" Margin="12,6,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Content="Tên Loại khách hàng" FontSize="24"/>
                    <ComboBox x:Name="cboLoaiKH" Height="40" FontSize="24" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Label Content="Ngày lập thẻ" FontSize="24"/>
                    <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Margin="8,0,8,0">
                        <DatePicker x:Name="dpNgayLapThe" Height="40" FontSize="24" BorderThickness="0" Language="vi-VN"
                                    SelectedDateChanged="dpNgayLapThe_SelectedDateChanged">
                            <DatePicker.Resources>
                                <Style TargetType="DatePickerTextBox">
                                    <Setter Property="IsReadOnly" Value="True"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <Label Content="Ngày hết hạn" FontSize="24"/>
                    <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                        <TextBlock x:Name="txtNgayHetHan" FontSize="24" VerticalAlignment="Center" Margin="8,0"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Đường kẻ ngang -->
            <Border Grid.Row="8" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nút bấm -->
            <Grid Grid.Row="9" Margin="12,10,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Tiếp nhận khách hàng"
                        Height="45" Width="250"
                        HorizontalAlignment="Left"
                        FontSize="20"
                        Background="#00BCD4"
                        Foreground="White"
                        BorderThickness="1"
                        Click="BtnTiepNhan_Click"/>

                <Button Grid.Column="1" Content="Thoát"
                        Height="45" Width="120"
                        FontSize="20"
                        Background="#00BCD4"
                        Foreground="White"
                        BorderThickness="1"
                        Click="BtnThoat_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>