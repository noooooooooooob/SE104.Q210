<Window x:Class="Sprint2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lập Phiếu Nhập Game"
        Height="650"
        Width="900">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Thông tin Game"
                  Grid.Row="0">

            <Grid Margin="10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Text="Ngày nhập"/>
                <DatePicker
                    x:Name="dpNgayNhap"
                    Grid.Column="1"/>

                <TextBlock
                    Grid.Row="1"
                    Text="Tên Game"/>

                <TextBox
                    x:Name="txtTenGame"
                    Grid.Row="1"
                    Grid.Column="1"/>

                <TextBlock
                    Grid.Row="2"
                    Text="Loại Game"/>

                <ComboBox
                    x:Name="cbLoaiGame"
                    Grid.Row="2"
                    Grid.Column="1"/>

                <TextBlock
                    Grid.Row="3"
                    Text="Nhà phát hành"/>

                <TextBox
                    x:Name="txtNhaPhatHanh"
                    Grid.Row="3"
                    Grid.Column="1"/>

                <TextBlock
                    Grid.Row="4"
                    Text="Năm phát hành"/>

                <TextBox
                    x:Name="txtNamPhatHanh"
                    Grid.Row="4"
                    Grid.Column="1"/>

                <TextBlock
                    Grid.Row="5"
                    Text="Trị giá"/>

                <TextBox
                    x:Name="txtTriGia"
                    Grid.Row="5"
                    Grid.Column="1"/>

                <Button
                    Grid.Row="6"
                    Grid.Column="1"
                    Margin="0,10,0,0"
                    Content="Thêm Game"
                    Click="BtnThemGame_Click"/>

            </Grid>

        </GroupBox>

        <DataGrid
            Grid.Row="1"
            Margin="0,10,0,10"
            x:Name="dgGames"/>

        <StackPanel Grid.Row="2">

            <TextBlock
                x:Name="txtTongGiaTri"
                FontSize="16"
                FontWeight="Bold"
                Text="Tổng giá trị: 0"/>

            <Button
                Width="200"
                Height="40"
                Margin="0,10,0,0"
                Content="Lập Phiếu Nhập"
                Click="BtnLapPhieu_Click"/>

        </StackPanel>

    </Grid>

</Window>
