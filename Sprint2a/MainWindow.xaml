<Window x:Class="Sprint2a.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sprint2a"
        mc:Ignorable="d"
        Title="Lập phiếu nhập Game"
        Height="605"
        Width="1400"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        WindowStartupLocation="CenterScreen">

    <Border BorderBrush="Black"
            BorderThickness="1"
            Margin="10"
            CornerRadius="8">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="65"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Grid Grid.Row="0">
                <TextBlock Text="Lập phiếu nhập Game"
                           FontSize="24"
                           Margin="20,10"/>
            </Grid>

            <!-- Đường kẻ -->
            <Border Grid.Row="1" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nội dung -->
            <Border Grid.Row="2"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="#EEF1F5"
                    Margin="10,15,10,10"
                    Padding="10">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- FORM (4 cột: Mã phiếu nhập | Ngày nhập | Quy định tuổi | Tổng tiền) -->
                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mã phiếu nhập -->
                        <StackPanel Grid.Column="0">
                            <Label Content="Mã phiếu nhập" FontSize="18"/>
                            <Border Background="#A0A0A0" Height="40" CornerRadius="5">
                                <TextBlock x:Name="txtMaPN"
                                           Text="&lt;Giá trị phát sinh&gt;"
                                           Foreground="Gray"
                                           FontStyle="Italic" FontSize="18"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <!-- Ngày nhập -->
                        <StackPanel Grid.Column="2">
                            <Label Content="Ngày nhập" FontSize="18"/>
                            <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40" Background="White">
                                <DatePicker x:Name="dpNgayNhap" Height="40" FontSize="24" BorderThickness="0" Language="vi-VN" Background="White" VerticalContentAlignment="Center" SelectedDateChanged="DpNgayNhap_SelectedDateChanged" DisplayDateStart="{x:Static sys:DateTime.Today}">
                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="IsReadOnly" Value="True"/>
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                            </Border>
                        </StackPanel>

                        <!-- Quy định tuổi game -->
                        <StackPanel Grid.Column="4">
                            <Label Content="Quy định tuổi game" FontSize="18"/>
                            <Border Background="#A0A0A0" Height="40" CornerRadius="5">
                                <TextBlock x:Name="txtQuiDinhTuoiGame"
                                           FontSize="18"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <!-- Tổng tiền -->
                        <StackPanel Grid.Column="6">
                            <Label Content="Tổng tiền" FontSize="18"/>
                            <Border Background="#A0A0A0" Height="40" CornerRadius="5">
                                <TextBlock x:Name="txtTongTien"
                                           FontSize="18"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                    </Grid>

                    <!-- BẢNG -->
                    <Border Grid.Row="2"
                            BorderBrush="#CCCCCC"
                            BorderThickness="2"
                            CornerRadius="5"
                            Background="White"
                            Margin="12,12,12,12"
                            Padding="10">

                        <DataGrid x:Name="dgGames"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#CCCCCC"
                                  VerticalGridLinesBrush="#CCCCCC"
                                  Background="White"
                                  BorderThickness="0"
                                  FontSize="16">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Height" Value="40"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="50"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>

                                <!-- STT -->
                                <DataGridTemplateColumn Header="STT" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding STT}"
                                                    Width="35" Height="35"
                                                    FontSize="18" FontWeight="Bold"
                                                    Background="Transparent"
                                                    Click="BtnSTT_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- MÃ CT PHIẾU NHẬP (phát sinh, read-only) -->
                                <DataGridTemplateColumn Header="MÃ CT PHIẾU NHẬP" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#A0A0A0" Height="40" CornerRadius="5">
                                                <TextBlock Text="{Binding MaCTPN}"
                                                           FontSize="16" FontStyle="Italic"
                                                           Foreground="Gray"
                                                           VerticalAlignment="Center" Margin="6,0"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- TÊN GAME -->
                                <DataGridTemplateColumn Header="TÊN GAME" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1"
                                                    CornerRadius="5" Height="40">
                                                <TextBox Height="35" BorderThickness="0" FontSize="16"
                                                         VerticalContentAlignment="Center" Margin="1,0"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- TÊN LOẠI GAME -->
                                <DataGridTemplateColumn Header="TÊN LOẠI GAME" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox x:Name="cboLoaiGame"
                                                      Height="38" FontSize="16"
                                                      Loaded="CboLoaiGame_Loaded"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- NHÀ PHÁT HÀNH -->
                                <DataGridTemplateColumn Header="NHÀ PHÁT HÀNH" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1"
                                                    CornerRadius="5" Height="40">
                                                <TextBox Height="35" BorderThickness="0" FontSize="16"
                                                         VerticalContentAlignment="Center" Margin="1,0"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- NĂM PHÁT HÀNH -->
                                <DataGridTemplateColumn Header="NĂM PHÁT HÀNH" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Height="40">
                                                <TextBox Height="35" BorderThickness="0" FontSize="16"
                                                 VerticalContentAlignment="Center" Margin="1,0"
                                                 PreviewTextInput="NumberOnly_PreviewTextInput"
                                                 TextChanged="TxtNamPhatHanh_TextChanged"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- TUỔI GAME -->
                                <DataGridTemplateColumn Header="TUỔI GAME" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#E0E0E0" Height="40" CornerRadius="5">
                                                <TextBlock FontSize="16"
                                                           VerticalAlignment="Center" Margin="8,0"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- TRỊ GIÁ -->
                                <DataGridTemplateColumn Header="TRỊ GIÁ" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#AAAAAA" BorderThickness="1"
                                                    CornerRadius="5" Height="40">
                                                <TextBox Height="35" BorderThickness="0" FontSize="16"
                                                         VerticalContentAlignment="Center" Margin="1,0"
                                                         PreviewTextInput="NumberOnly_PreviewTextInput"
                                                         TextChanged="TxtTriGia_TextChanged"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>

                        </DataGrid>

                    </Border>

                </Grid>

            </Border>

            <!-- Đường kẻ -->
            <Border Grid.Row="3" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nút -->
            <Grid Grid.Row="4" Margin="12,10,12,12">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Lập phiếu nhập"
                        Height="45" Width="160"
                        FontSize="20"
                        Background="#00BCD4"
                        Foreground="White"
                        BorderThickness="1"
                        Click="BtnLapPhieuNhap_Click"/>

                <Button Grid.Column="2" Content="Tra cứu Game"
                        Height="45" Width="130"
                        FontSize="20"
                        Background="#00BCD4"
                        Foreground="White"
                        BorderThickness="1"/>

                <Button Grid.Column="4" Content="Thoát"
                        Height="45" Width="120"
                        FontSize="20"
                        Background="#00BCD4"
                        Foreground="White"
                        BorderThickness="1"
                        Click="BtnThoat_Click"/>

            </Grid>

        </Grid>

    </Border>

</Window>