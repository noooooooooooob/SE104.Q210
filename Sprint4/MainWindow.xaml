<Window x:Class="Sprint4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lập phiếu cho mượn Game"
        Height="610" Width="900"
        WindowStartupLocation="CenterScreen"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Loaded="Window_Loaded">

    <Border BorderBrush="Black" BorderThickness="1" CornerRadius="8" Margin="10" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="65"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <TextBlock Grid.Row="0" Text="Lập phiếu cho mượn Game"
                       FontSize="22" FontWeight="Bold" Margin="20,12,0,12"/>

            <Border Grid.Row="1" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nội dung -->
            <Border Grid.Row="2" Margin="12,12,12,12" Padding="14"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="5" Background="#EEF1F5">
                <StackPanel>

                    <!-- HÀNG 1: Mã phiếu | Họ tên KH | Ngày hết hạn | Ngày mượn | Ngày hết hạn mượn -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mã phiếu mượn -->
                        <StackPanel Grid.Column="0">
                            <Label Content="Mã phiếu mượn" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbMaPhieuMuon"
                                           Text="&lt;Giá trị phát sinh&gt;"
                                           FontSize="13" Foreground="#888"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <!-- Họ tên khách hàng -->
                        <StackPanel Grid.Column="2">
                            <Label Content="Họ tên khách hàng" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="White">
                                <ComboBox x:Name="cboKhachHang" Height="32" FontSize="13"
                                          BorderThickness="0" VerticalContentAlignment="Center"
                                          SelectionChanged="CboKhachHang_SelectionChanged"/>
                            </Border>
                        </StackPanel>

                        <!-- Ngày hết hạn thẻ -->
                        <StackPanel Grid.Column="4">
                            <Label Content="Ngày hết hạn" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbNgayHetHan" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <!-- Ngày mượn -->
                        <StackPanel Grid.Column="6">
                            <Label Content="Ngày mượn" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="White">
                                <DatePicker x:Name="dpNgayMuon" Height="36" FontSize="13"
                                            BorderThickness="0" Background="White"
                                            VerticalContentAlignment="Center"
                                            SelectedDateChanged="DpNgayMuon_SelectedDateChanged"
                                            DisplayDateStart="{x:Static sys:DateTime.Today}">
                                    <DatePicker.Resources>
                                        <Style TargetType="DatePickerTextBox">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DatePicker.Resources>
                                </DatePicker>
                            </Border>
                        </StackPanel>

                        <!-- Ngày hết hạn mượn -->
                        <StackPanel Grid.Column="8">
                            <Label Content="Ngày hết hạn mượn" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbNgayHetHanMuon" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- HÀNG 2: Quy định số game | Quy định số ngày -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Quy định số game cho mượn" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbQuyDinhSoGame" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <Label Content="Quy định số ngày mượn" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbQuyDinhSoNgay" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- BẢNG GAME -->
                    <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4" Background="White">
                        <StackPanel>

                            <!-- Header -->
                            <Grid Background="#D8DCE2" Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="STT" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="TÊN GAME" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="TÊN LOẠI GAME" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="NHÀ PHÁT HÀNH" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="TÌNH TRẠNG" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"/>

                            <!-- ROW 1 -->
                            <Grid Height="44" Margin="6,4,6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="1" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="White" Margin="4,4">
                                    <ComboBox x:Name="cboGame1" FontSize="13" BorderThickness="0"
                                              VerticalContentAlignment="Center" Tag="1"
                                              SelectionChanged="CboGame_SelectionChanged"/>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbLoai1" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="3" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbNPH1" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="4" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbTT1" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                            </Grid>

                            <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0"/>

                            <!-- ROW 2 -->
                            <Grid Height="44" Margin="6,4,6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="2" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="White" Margin="4,4">
                                    <ComboBox x:Name="cboGame2" FontSize="13" BorderThickness="0"
                                              VerticalContentAlignment="Center" Tag="2"
                                              SelectionChanged="CboGame_SelectionChanged"/>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbLoai2" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="3" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbNPH2" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="4" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbTT2" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                            </Grid>

                            <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0"/>

                            <!-- ROW 3 -->
                            <Grid Height="44" Margin="6,4,6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="3" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="White" Margin="4,4">
                                    <ComboBox x:Name="cboGame3" FontSize="13" BorderThickness="0"
                                              VerticalContentAlignment="Center" Tag="3"
                                              SelectionChanged="CboGame_SelectionChanged"/>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbLoai3" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="3" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbNPH3" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="4" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbTT3" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                            </Grid>

                            <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0"/>

                            <!-- ROW 4 -->
                            <Grid Height="44" Margin="6,4,6,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="4" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="White" Margin="4,4">
                                    <ComboBox x:Name="cboGame4" FontSize="13" BorderThickness="0"
                                              VerticalContentAlignment="Center" Tag="4"
                                              SelectionChanged="CboGame_SelectionChanged"/>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbLoai4" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="3" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbNPH4" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                                <Border Grid.Column="4" BorderBrush="#AAAAAA" BorderThickness="1"
                                        CornerRadius="4" Background="#E0E0E0" Margin="4,4">
                                    <TextBlock x:Name="txbTT4" FontSize="13" VerticalAlignment="Center" Margin="6,0"/>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <Border Grid.Row="3" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nút bấm -->
            <Grid Grid.Row="4" Margin="12,12,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Lập phiếu cho mượn Game"
                        Height="42" Width="230" FontSize="16"
                        Background="#00BCD4" Foreground="White" BorderThickness="1"
                        Click="BtnLapPhieu_Click"/>

                <Button Grid.Column="2" Content="Thoát"
                        Height="42" Width="100" FontSize="16"
                        Background="#00BCD4" Foreground="White" BorderThickness="1"
                        Click="BtnThoat_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>
