<Window x:Class="Sprint6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lập phiếu thu tiền phạt"
        Height="320" Width="620"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Border BorderBrush="Black" BorderThickness="1" CornerRadius="8" Margin="10" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="65"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <TextBlock Grid.Row="0" Text="Lập phiếu thu tiền phạt"
                       FontSize="22" FontWeight="Bold" Margin="20,12,0,12"/>

            <Border Grid.Row="1" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nội dung -->
            <Border Grid.Row="2" Margin="12,12,12,12" Padding="14"
                    BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="5" Background="#EEF1F5">
                <StackPanel>

                    <!-- HÀNG 1: Mã phiếu thu tiền | Họ tên KH | Tiền nợ -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mã phiếu thu tiền -->
                        <StackPanel Grid.Column="0">
                            <Label Content="Mã phiếu thu tiền" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbMaPhieuThu"
                                           Text="&lt;Giá trị phát sinh&gt;"
                                           FontSize="13" Foreground="#888"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>

                        <!-- Họ tên khách hàng -->
                        <StackPanel Grid.Column="2">
                            <Label Content="Họ tên khách hàng" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="White">
                                <ComboBox x:Name="cboKhachHang" Height="32" FontSize="13"
                                          BorderThickness="0" VerticalContentAlignment="Center"
                                          SelectionChanged="CboKhachHang_SelectionChanged"/>
                            </Border>
                        </StackPanel>

                        <!-- Tiền nợ -->
                        <StackPanel Grid.Column="4">
                            <Label Content="Tiền nợ" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbTienNo" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- HÀNG 2: Số tiền thu | Số tiền còn lại -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Số tiền thu (TextBox, nhập được) -->
                        <StackPanel Grid.Column="0">
                            <Label Content="Số tiền thu" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="White">
                                <TextBox x:Name="txtSoTienThu" FontSize="13"
                                         BorderThickness="0" VerticalContentAlignment="Center"
                                         Margin="6,0"
                                         TextChanged="TxtSoTienThu_TextChanged"/>
                            </Border>
                        </StackPanel>

                        <!-- Số tiền còn lại -->
                        <StackPanel Grid.Column="2">
                            <Label Content="Số tiền còn lại" FontSize="13" Padding="0,0,0,2"/>
                            <Border BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4"
                                    Height="36" Background="#E0E0E0">
                                <TextBlock x:Name="txbSoTienConLai" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <Border Grid.Row="3" BorderBrush="#AAAAAA" BorderThickness="0,1,0,0"/>

            <!-- Nút bấm -->
            <Grid Grid.Row="4" Margin="12,12,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Lập phiếu thu tiền phạt"
                        Height="42" Width="220" FontSize="16"
                        Background="#00BCD4" Foreground="White" BorderThickness="1"
                        Click="BtnLapPhieu_Click"/>

                <Button Grid.Column="2" Content="Thoát"
                        Height="42" Width="100" FontSize="16"
                        Background="#00BCD4" Foreground="White" BorderThickness="1"
                        Click="BtnThoat_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>